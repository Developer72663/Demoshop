<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registration Successful - Blogify</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .gradient-bg { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
        .checkmark-circle { stroke-dasharray: 166; stroke-dashoffset: 166; animation: stroke 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards; }
        .checkmark-check { stroke-dasharray: 48; stroke-dashoffset: 48; animation: stroke 0.3s cubic-bezier(0.65, 0, 0.45, 1) 0.6s forwards; }
        @keyframes stroke { 100% { stroke-dashoffset: 0; } }
        .animate-bounce-in { animation: bounceIn 0.8s ease-out; }
        @keyframes bounceIn { 0% { opacity: 0; transform: scale(0.3); } 50% { transform: scale(1.05); } 70% { transform: scale(0.9); } 100% { opacity: 1; transform: scale(1); } }
    </style>
</head>
<body class="gradient-bg min-h-screen flex items-center justify-center p-4">
    <div class="w-full max-w-lg animate-bounce-in">
        <div class="bg-white rounded-3xl shadow-2xl p-10 text-center">
            <!-- Animated Checkmark -->
            <div class="flex justify-center mb-6">
                <svg class="w-24 h-24" viewBox="0 0 52 52">
                    <circle class="checkmark-circle" cx="26" cy="26" r="25" fill="none" stroke="#10b981" stroke-width="2"/>
                    <path class="checkmark-check" fill="none" stroke="#10b981" stroke-width="3" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
                </svg>
            </div>

            <h1 class="text-3xl font-bold text-gray-800 mb-3">Welcome, Seller!</h1>
            <p class="text-gray-600 mb-2">Your seller account has been successfully created.</p>
            <p class="text-gray-500 text-sm mb-8">You can now start listing products and managing your store.</p>

            <div class="space-y-3">
                <a href="/seller/dashboard" 
                    class="block w-full bg-gradient-to-r from-purple-600 to-blue-600 text-white font-semibold py-4 px-6 rounded-xl hover:shadow-lg hover:shadow-purple-500/30 transition-all">
                    Go to Seller Dashboard
                </a>
                <a href="/" 
                    class="block w-full bg-gray-100 text-gray-700 font-semibold py-4 px-6 rounded-xl hover:bg-gray-200 transition-all">
                    Back to Home
                </a>
            </div>

            <% if (user) { %>
            <div class="mt-6 pt-6 border-t border-gray-100">
                <div class="flex items-center justify-center space-x-3">
                    <img src="<%= user.profileImageURL %>" alt="Profile" class="w-10 h-10 rounded-full">
                    <div class="text-left">
                        <p class="text-sm font-medium text-gray-800"><%= user.fullName %></p>
                        <p class="text-xs text-gray-500"><%= user.email %></p>
                    </div>
                </div>
            </div>
            <% } %>
        </div>
    </div>
</body>
</html>

